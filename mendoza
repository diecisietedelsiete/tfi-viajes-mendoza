    const STORAGE_KEY_PUZZLE_TIME = "puzzleTimeRanking";

    // Variables puzzle
    let puzzleBoard = [], puzzleSelected = null, puzzleMoves = 0, puzzleGameActive = false, puzzleGameCompleted = false;
