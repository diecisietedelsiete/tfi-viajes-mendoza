    const ROWS = 4, COLS = 5;
    const TARGET_WORDS = [
        "oooooo\nModelo de\nContexto S1\nooooo↘️\n", "\n>>>>>>>>>\n\n\n", "\n>>Ámbito<<\nsociocultural\n\n", "\n<<<<<<<<<\n\n\n",
