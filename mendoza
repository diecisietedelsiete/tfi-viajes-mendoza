        "💬📲💻✆➤\nMENSAJE\nconformado\nmediante\nun lenguaje", "\nSUJETO 2\n🧑‍👦🏻‍👧🏻\n(indiv. o col.)\n", "<\n<\n🧑<\n<\n<",
        ">\n>\n>\n>\n>", "querer\ndecir\n\n\n", "\n\ndirecta o mediada\n\n", "querer\ncomprender\n\n\n", "<\n<\n<\n<\n<",
        "\n>\n>\n>\n....>>>>", "-------------\nconocimientos\n-------------\n\n>>>>>>>>>>", "-------------\ny creencias\n-------------\n\n>>>>><<<<",
        "-------------\ns/ el mundo\n-------------\n\n<<<<<<<<<<", "\n<\n<\n<\n<<<<...."
    ];

    // DOM
    const screenStart = document.getElementById('screen-start');
    const gameArea = document.getElementById('gameArea');
    const screenTransition = document.getElementById('screen-transition');
    const screenPuzzle = document.getElementById('screen-puzzle');
    const screenVictory = document.getElementById('screen-victory');
    const playerDiv = document.getElementById('player');
    const gameTimerSpan = document.getElementById('game-timer');
    const messageDiv = document.getElementById('message');
    const playerNameInput = document.getElementById('player-name');
    const btnStart = document.getElementById('btn-start-game');
    const btnRestart = document.getElementById('btn-restart');
    const btnGoPuzzle = document.getElementById('btn-go-puzzle');
    const rankingBodyStart2 = document.getElementById('ranking-body-start2');
    const rankingBodyEnd = document.getElementById('ranking-body-end');
    const rankingBodyPuzzleTime = document.getElementById('ranking-body-puzzle-time');
    const puzzleGrid = document.getElementById('puzzleGrid');
    const timerDisplay = document.getElementById('timerDisplay');
    const movesSpan = document.getElementById('movesCount');
    const startPuzzleBtn = document.getElementById('startBtn');
    const resetPuzzleBtn = document.getElementById('resetPuzzleBtn');
    const globalMsgPuzzle = document.getElementById('globalMsg');
    const puzzlePlayerNameDisplay = document.getElementById('puzzlePlayerNameDisplay');
    const orientationWarning = document.getElementById('orientation-warning');
    const understoodBtn = document.getElementById('understood-btn');
    const puzzleWarning = document.getElementById('puzzle-warning');
    const puzzleContent = document.getElementById('puzzle-content');
    
    // Nuevos elementos de controles táctiles en esquinas
    const touchLeftCorner = document.getElementById('touch-left-corner');
    const touchRightCorner = document.getElementById('touch-right-corner');

    // Ranking
    function getRanking() { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
    function getPuzzleMovesRanking() { return JSON.parse(localStorage.getItem(STORAGE_KEY_PUZZLE_MOVES)) || []; }
    function getPuzzleTimeRanking() { return JSON.parse(localStorage.getItem(STORAGE_KEY_PUZZLE_TIME)) || []; }

    function saveScoreToRanking(name, timeSec) {
        let r = getRanking();
        r.push({ name: name.toUpperCase(), time: timeSec });
        r.sort((a, b) => a.time - b.time);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(r.slice(0, 5)));
    }

    function savePuzzleMovesToRanking(name, moves) {
        let r = getPuzzleMovesRanking();
        r.push({ name: name.toUpperCase(), moves: moves });
        r.sort((a, b) => a.moves - b.moves);
        localStorage.setItem(STORAGE_KEY_PUZZLE_MOVES, JSON.stringify(r.slice(0, 5)));
    }

    function savePuzzleTimeToRanking(name, timeSec) {
        let r = getPuzzleTimeRanking();
        r.push({ name: name.toUpperCase(), time: timeSec });
        r.sort((a, b) => a.time - b.time);
        localStorage.setItem(STORAGE_KEY_PUZZLE_TIME, JSON.stringify(r.slice(0, 5)));
    }

    function updateRankingTables() {
        let rCollect = getRanking();
        if (rankingBodyStart2) {
            rankingBodyStart2.innerHTML = '';
            if (rCollect.length === 0) rankingBodyStart2.innerHTML = '<tr><td colspan="3">✨ Sin registros ✨</td>';
            else rCollect.forEach((e, i) => {
                let mins = Math.floor(e.time / 60), secs = e.time % 60;
                rankingBodyStart2.innerHTML += `<tr><td>${i+1}侧<td>${e.name}侧<td>${mins.toString().padStart(2,'0')}:${secs.toString().padStart(2,'0')}侧</tr>`;
            });
        }
        let rMoves = getPuzzleMovesRanking();
        if (rankingBodyEnd) {
            rankingBodyEnd.innerHTML = '';
            if (rMoves.length === 0) rankingBodyEnd.innerHTML = '<tr><td colspan="3">✨ Sin registros ✨</td>';
            else rMoves.forEach((e, i) => rankingBodyEnd.innerHTML += `<tr><td>${i+1}侧<td>${e.name}侧<td>${e.moves}侧<tr>`);
        }
        let rTime = getPuzzleTimeRanking();
        if (rankingBodyPuzzleTime) {
            rankingBodyPuzzleTime.innerHTML = '';
            if (rTime.length === 0) rankingBodyPuzzleTime.innerHTML = '<tr><td colspan="3">✨ Sin registros ✨</td>';
            else rTime.forEach((e, i) => rankingBodyPuzzleTime.innerHTML += `<tr><td>${i+1}侧<td>${e.name}侧<td>${e.time.toFixed(1)} seg侧</tr>`);
        }
    }

    // Recolección (igual que antes)
    function updateWordListDisplay() {
        const wordListEl = document.getElementById('word-list');
        if (!wordListEl) return;
        wordListEl.innerHTML = '';
        GOOD_WORDS.forEach(word => {
            const li = document.createElement('li');
            li.textContent = word;
            if (collected.includes(word)) li.classList.add('collected');
            else li.classList.add('missing');
            wordListEl.appendChild(li);
        });
    }

    function startGame() {
        if (gameActive) return;
        collected = [];
        collectionSeconds = 0;
        leaves.forEach(l => l.element.remove());
        leaves = [];
        updateWordListDisplay();
        gameActive = true;
        const containerRect = gameArea.getBoundingClientRect();
        playerX = containerRect.width / 2;
        playerDiv.style.left = playerX + 'px';
        gameTimerSpan.innerText = '00:00';
        messageDiv.innerText = '⬅️ ➡️ mover · Atrapá las hojas';
        screenStart.classList.add('hidden');
        gameArea.style.display = 'block';
        screenTransition.classList.add('hidden');
        screenPuzzle.classList.add('hidden');
        screenVictory.classList.add('hidden');
        
        // Mostrar controles táctiles en esquinas
        if (touchLeftCorner) touchLeftCorner.classList.remove('hidden-controls');
        if (touchRightCorner) touchRightCorner.classList.remove('hidden-controls');
        
        if (gameTimer) clearInterval(gameTimer);
        gameTimer = setInterval(() => {
            if (gameActive) {
                collectionSeconds++;
                let min = Math.floor(collectionSeconds / 60), sec = collectionSeconds % 60;
                gameTimerSpan.innerText = `${min.toString().padStart(2, '0')}:${sec.toString().padStart(2, '0')}`;
            }
        }, 1000);
        if (spawnInterval) clearInterval(spawnInterval);
        spawnInterval = setInterval(() => { if (gameActive) spawnLeaf(); }, 700);
    }

    function spawnLeaf() {
        const isGood = Math.random() > 0.4;
        const word = isGood ? GOOD_WORDS[Math.floor(Math.random() * GOOD_WORDS.length)] : BAD_WORDS_LIST[Math.floor(Math.random() * BAD_WORDS_LIST.length)];
        const leaf = document.createElement('div');
        leaf.className = 'leaf';
        leaf.innerHTML = `🍂 ${word} 🍂`;
        leaf.style.left = Math.random() * (window.innerWidth - 100) + 'px';
        leaf.style.animationDuration = (Math.random() * 4 + 4) + 's';
        document.getElementById('gameArea').appendChild(leaf);
        leaves.push({ element: leaf, word: word, isGood: isGood });
    }

    function collectLeaf(leafObj) {
        if (leafObj.isGood) {
            if (!collected.includes(leafObj.word)) {
                collected.push(leafObj.word);
                updateWordListDisplay();
                messageDiv.innerText = `✅ Atrapaste: ${leafObj.word}`;
                setTimeout(() => {
                    if (messageDiv.innerText === `✅ Atrapaste: ${leafObj.word}`) messageDiv.innerText = '⬅️ ➡️ mover · Atrapá las hojas';
                }, 1000);
                if (collected.length === 14) {
                    gameActive = false;
                    if (gameTimer) clearInterval(gameTimer);
                    if (spawnInterval) clearInterval(spawnInterval);
                    saveScoreToRanking(playerNameInput.value.trim().toUpperCase() || "ANÓNIMO", collectionSeconds);
                    updateRankingTables();
                    gameArea.style.display = 'none';
                    if (touchLeftCorner) touchLeftCorner.classList.add('hidden-controls');
                    if (touchRightCorner) touchRightCorner.classList.add('hidden-controls');
                    screenTransition.classList.remove('hidden');
                }
            }
        } else {
            if (collected.length > 0) {
                const lost = collected.pop();
                updateWordListDisplay();
                messageDiv.innerText = `❌ Perdiste: ${lost}`;
                setTimeout(() => {
                    if (messageDiv.innerText === `❌ Perdiste: ${lost}`) messageDiv.innerText = '⬅️ ➡️ mover · Atrapá las hojas';
                }, 1000);
            } else {
                messageDiv.innerText = '❌ No tenés conceptos para perder!';
                setTimeout(() => {
                    if (messageDiv.innerText === '❌ No tenés conceptos para perder!') messageDiv.innerText = '⬅️ ➡️ mover · Atrapá las hojas';
                }, 1000);
            }
        }
        leafObj.element.remove();
        leaves = leaves.filter(l => l !== leafObj);
    }

    function updatePlayerPosition() {
        const containerRect = gameArea.getBoundingClientRect();
        let minX = 20, maxX = containerRect.width - 70;
        if (playerX < minX) playerX = minX;
        if (playerX > maxX) playerX = maxX;
        playerDiv.style.left = playerX + 'px';
    }

    function checkCollisions() {
        const playerRect = playerDiv.getBoundingClientRect();
        for (let i = leaves.length - 1; i >= 0; i--) {
            const leaf = leaves[i];
            const leafRect = leaf.element.getBoundingClientRect();
            if (playerRect.left < leafRect.right && playerRect.right > leafRect.left && playerRect.top < leafRect.bottom && playerRect.bottom > leafRect.top) collectLeaf(leaf);
        }
    }

    // Puzzle
    function initPuzzleBoard() {
        let newBoard = [], idx = 0;
        for (let i = 0; i < ROWS; i++) {
            newBoard[i] = [];
            for (let j = 0; j < COLS; j++) newBoard[i][j] = TARGET_WORDS[idx++];
        }
        return newBoard;
    }

    function shufflePuzzleBoard(boardRef, steps = 800) {
        for (let s = 0; s < steps; s++) {
            const r1 = Math.floor(Math.random() * ROWS), c1 = Math.floor(Math.random() * COLS);
            const r2 = Math.floor(Math.random() * ROWS), c2 = Math.floor(Math.random() * COLS);
            const temp = boardRef[r1][c1];
            boardRef[r1][c1] = boardRef[r2][c2];
            boardRef[r2][c2] = temp;
        }
        return boardRef;
    }

    function isPuzzleSolved(boardRef) {
        let idx = 0;
        for (let i = 0; i < ROWS; i++)
            for (let j = 0; j < COLS; j++)
                if (boardRef[i][j] !== TARGET_WORDS[idx++]) return false;
        return true;
    }

    function renderPuzzleBoard() {
        if (!puzzleGrid) return;
        puzzleGrid.innerHTML = '';
        for (let i = 0; i < ROWS; i++) {
            for (let j = 0; j < COLS; j++) {
                const value = puzzleBoard[i][j];
                const isSelected = (puzzleSelected && puzzleSelected.row === i && puzzleSelected.col === j);
                const tile = document.createElement('div');
                tile.className = 'puzzle-tile';
                if (isSelected) tile.classList.add('selected');
                tile.textContent = value;
                tile.addEventListener('click', (function(r, c) { return function() { selectPuzzleTile(r, c); }; })(i, j));
                puzzleGrid.appendChild(tile);
            }
        }
    }

    function selectPuzzleTile(row, col) {
        if (!puzzleGameActive || puzzleGameCompleted) return;
        if (puzzleSelected === null) {
            puzzleSelected = { row, col };
            renderPuzzleBoard();
            return;
        }
        const temp = puzzleBoard[puzzleSelected.row][puzzleSelected.col];
        puzzleBoard[puzzleSelected.row][puzzleSelected.col] = puzzleBoard[row][col];
        puzzleBoard[row][col] = temp;
        puzzleMoves++;
        movesSpan.innerText = puzzleMoves;
        puzzleSelected = null;
        renderPuzzleBoard();
        if (isPuzzleSolved(puzzleBoard)) {
            puzzleGameCompleted = true;
            if (puzzleTimerInterval) clearInterval(puzzleTimerInterval);
            const elapsed = (Date.now() - puzzleStartTime) / 1000;
            timerDisplay.innerText = elapsed.toFixed(1);
            const playerName = playerNameInput.value.trim().toUpperCase() || "ANÓNIMO";
            savePuzzleMovesToRanking(playerName, puzzleMoves);
            savePuzzleTimeToRanking(playerName, elapsed);
            updateRankingTables();
            screenPuzzle.classList.add('hidden');
            screenVictory.classList.remove('hidden');
        }
    }

    function resetPuzzleState() {
        if (puzzleTimerInterval) clearInterval(puzzleTimerInterval);
        puzzleGameActive = false;
        puzzleGameCompleted = false;
        puzzleMoves = 0;
        puzzleSelected = null;
        movesSpan.innerText = "0";
        timerDisplay.innerText = "0.0";
        puzzleBoard = initPuzzleBoard();
        renderPuzzleBoard();
        globalMsgPuzzle.innerHTML = "🔄 Puzzle reiniciado. Presioná 'INICIAR' para empezar.";
        setTimeout(() => { if (globalMsgPuzzle.innerHTML === "🔄 Puzzle reiniciado. Presioná 'INICIAR' para empezar.") globalMsgPuzzle.innerHTML = ""; }, 2000);
    }

    function startPuzzleGame() {
        if (puzzleGameActive) return;
        if (puzzleTimerInterval) clearInterval(puzzleTimerInterval);
        puzzleGameActive = true;
        puzzleGameCompleted = false;
        puzzleMoves = 0;
        puzzleSelected = null;
        movesSpan.innerText = "0";
        puzzleBoard = initPuzzleBoard();
        puzzleBoard = shufflePuzzleBoard(puzzleBoard, 800);
        renderPuzzleBoard();
        puzzleStartTime = Date.now();
        puzzleTimerInterval = setInterval(() => {
            if (puzzleGameActive && !puzzleGameCompleted) {
                const elapsed = (Date.now() - puzzleStartTime) / 1000;
                timerDisplay.innerText = elapsed.toFixed(1);
            }
        }, 100);
        globalMsgPuzzle.innerHTML = "🧩 ¡PUZZLE INICIADO! Intercambiá las fichas.";
        setTimeout(() => { if (globalMsgPuzzle.innerHTML === "🧩 ¡PUZZLE INICIADO! Intercambiá las fichas.") globalMsgPuzzle.innerHTML = ""; }, 2000);
    }

    function startPuzzleTransition() {
        screenTransition.classList.add('hidden');
        screenPuzzle.classList.remove('hidden');
        const playerName = playerNameInput.value.trim().toUpperCase() || "ANÓNIMO";
        if (puzzlePlayerNameDisplay) puzzlePlayerNameDisplay.innerText = playerName;
        puzzleBoard = initPuzzleBoard();
        renderPuzzleBoard();
        puzzleGameActive = false;
        puzzleGameCompleted = false;
        puzzleMoves = 0;
        puzzleSelected = null;
        movesSpan.innerText = "0";
        timerDisplay.innerText = "0.0";
        if (puzzleTimerInterval) clearInterval(puzzleTimerInterval);
        globalMsgPuzzle.innerHTML = "✅ Puzzle listo. Presioná 'INICIAR' para comenzar.";
        
        // Verificar orientación para el puzzle
        checkPuzzleOrientation();
    }
    
	function checkPuzzleOrientation() {
		const isMobile = /Android|webOS|iPhone|iPad|iPod/i.test(navigator.userAgent);
		if (!isMobile) {
			if (puzzleWarning) puzzleWarning.style.display = 'none';
			if (puzzleContent) puzzleContent.style.display = 'block';
			return;
		}
		const isLandscape = window.innerWidth > window.innerHeight;
		if (puzzleWarning && puzzleContent) {
			if (!isLandscape) {
				puzzleWarning.style.display = 'flex';
				puzzleContent.style.display = 'none';
				// También pausar el juego del puzzle si está activo
				if (puzzleGameActive) {
					puzzleGameActive = false;
					if (puzzleTimerInterval) clearInterval(puzzleTimerInterval);
				}
			} else {
				puzzleWarning.style.display = 'none';
				puzzleContent.style.display = 'block';
			}
		}
	}

    // Controles
    let leftPressed = false, rightPressed = false;
    
    function updateMovement() {
        if (!gameActive || gameArea.style.display !== 'block') return;
        if (leftPressed) playerX -= 14;
        if (rightPressed) playerX += 14;
        updatePlayerPosition();
    }

    function gameLoop() {
        updateMovement();
        checkCollisions();
        requestAnimationFrame(gameLoop);
    }

    // Teclado
    window.addEventListener('keydown', (e) => {
        if (gameActive && gameArea.style.display === 'block') {
            if (e.key === 'ArrowLeft') { e.preventDefault(); leftPressed = true; }
            if (e.key === 'ArrowRight') { e.preventDefault(); rightPressed = true; }
        }
    });
    window.addEventListener('keyup', (e) => {
        if (e.key === 'ArrowLeft') leftPressed = false;
        if (e.key === 'ArrowRight') rightPressed = false;
    });

    // Controles táctiles en esquinas
    if (touchLeftCorner) {
        touchLeftCorner.addEventListener('touchstart', (e) => { e.preventDefault(); if (gameActive) leftPressed = true; });
        touchLeftCorner.addEventListener('touchend', (e) => { e.preventDefault(); leftPressed = false; });
        touchLeftCorner.addEventListener('mousedown', () => { if (gameActive) leftPressed = true; });
        touchLeftCorner.addEventListener('mouseup', () => { leftPressed = false; });
    }
    if (touchRightCorner) {
        touchRightCorner.addEventListener('touchstart', (e) => { e.preventDefault(); if (gameActive) rightPressed = true; });
        touchRightCorner.addEventListener('touchend', (e) => { e.preventDefault(); rightPressed = false; });
        touchRightCorner.addEventListener('mousedown', () => { if (gameActive) rightPressed = true; });
        touchRightCorner.addEventListener('mouseup', () => { rightPressed = false; });
    }

    // Orientación para recolección (vertical)
    let warningVisible = false;
	function checkOrientation() {
		const isMobile = /Android|webOS|iPhone|iPad|iPod/i.test(navigator.userAgent);
		if (!isMobile) return;
		const isLandscape = window.innerWidth > window.innerHeight;
		
		// Para TODAS las pantallas del juego, forzar horizontal
		const juegoActivo = gameArea.style.display === 'block' || 
							screenPuzzle.classList.contains('hidden') === false ||
							screenTransition.classList.contains('hidden') === false;
		
		if (juegoActivo) {
			if (!isLandscape && !warningVisible) {
				orientationWarning.classList.add('show');
				warningVisible = true;
			} else if (isLandscape && warningVisible) {
				orientationWarning.classList.remove('show');
				warningVisible = false;
			}
		}
		// También verificar orientación específica del puzzle
		if (screenPuzzle.classList.contains('hidden') === false) {
			checkPuzzleOrientation();
		}
	}
    
    understoodBtn.addEventListener('click', () => {
        orientationWarning.classList.remove('show');
        warningVisible = false;
    });
    
    window.addEventListener('resize', () => { 
        checkOrientation(); 
        if (gameActive) updatePlayerPosition();
        if (screenPuzzle.classList.contains('hidden') === false) checkPuzzleOrientation();
    });
    window.addEventListener('orientationchange', () => { 
        setTimeout(checkOrientation, 50); 
        setTimeout(() => { if (gameActive) updatePlayerPosition(); }, 100);
        if (screenPuzzle.classList.contains('hidden') === false) setTimeout(checkPuzzleOrientation, 100);
    });

    btnStart.addEventListener('click', startGame);
    btnRestart.addEventListener('click', () => { startGame(); });
    btnGoPuzzle.addEventListener('click', startPuzzleTransition);
    startPuzzleBtn.addEventListener('click', startPuzzleGame);
    resetPuzzleBtn.addEventListener('click', resetPuzzleState);
    
    gameLoop();
    updateRankingTables();
    checkOrientation();
</script>
</body>
</html>
