<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Esquiador Semiótico - Invierno en Malargüe</title>
    <style>
        /* ========== RESTO DEL CSS (igual que antes, pero con la corrección abajo) ========== */
        * {
            user-select: none;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        /* CORRECCIÓN PARA ALTURA DE PANTALLA EN MÓVIL (BARRA DE DIRECCIONES) */
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            position: fixed;
            background: linear-gradient(135deg, #1a3a5a, #0a2a3a);
        }

        /* Solución para altura dinámica en móviles (chrome, safari) */
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Orbitron', monospace;
            height: -webkit-fill-available;
        }

        #game-container {
            position: relative;
            width: 100%;
            height: 100%;
            background-color: #ffffff;
            overflow: hidden;
        }

        @media (min-width: 768px) {
            body {
                padding: 20px;
                height: 100%;
            }
            #game-container {
                border-radius: 28px;
                box-shadow: 0 25px 45px rgba(0, 0, 0, 0.5);
                border: 3px solid #4a8a6a;
                max-width: 500px;
                max-height: 90vh;
                width: 100%;
                height: auto;
                aspect-ratio: 9 / 16;
            }
        }

        #sky {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, #c8e8ff, #ffffff);
        }

        #snow-ground {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 20px;
            background: #e0e0e0;
        }

        .snowflake {
            position: absolute;
            color: white;
            font-size: 1.5rem;
            pointer-events: none;
            /* MODIFICACIÓN 1: CAÍDA EN DIAGONAL */
            animation: fallDiagonal linear infinite;
        }
        /* Nueva animación para caída diagonal */
        @keyframes fallDiagonal {
            0% {
                transform: translateY(-10vh) translateX(0);
                opacity: 1;
            }
            100% {
                transform: translateY(100vh) translateX(30px);
                opacity: 0.3;
            }
        }

        .screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(145deg, #0a2a3a, #061a2a);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            backdrop-filter: blur(3px);
            overflow-y: auto;
            padding: 16px;
        }

        .screen.hidden { display: none; }
        .screen h1 { color: #ffdd99; font-size: 1.5rem; text-shadow: 0 0 8px #ffaa33; text-align: center; }
        .screen p { color: #f0f9ff; background: rgba(0,0,0,0.6); padding: 6px 12px; border-radius: 28px; font-size: 0.8rem; }

        .ranking-table {
            background: #0a1a2a;
            border-radius: 16px;
            padding: 12px;
            margin: 12px 0;
            border: 2px solid #ffaa33;
            width: 90%;
            max-width: 380px;
        }
        .ranking-table table { width: 100%; color: #bbf0ff; font-size: 0.75rem; }
        .ranking-table th, .ranking-table td { padding: 6px; text-align: center; border-bottom: 1px solid #2a5a6a; }
        .ranking-table th { color: #ffbc6e; }

        input {
            padding: 10px 18px;
            border-radius: 50px;
            border: none;
            background: #fff8e8;
            font-size: 0.85rem;
            text-align: center;
            width: 80%;
            max-width: 240px;
        }

        button, .travel-link {
            background: #daa520;
            border: none;
            padding: 10px 20px;
            border-radius: 50px;
            color: white;
            font-weight: bold;
            cursor: pointer;
            margin: 5px;
            box-shadow: 0 4px 0 #8a5618;
            text-decoration: none;
            display: inline-block;
        }
        button:active, .travel-link:active { transform: translateY(2px); box-shadow: none; }
        .travel-link { background: #2e8b57; box-shadow: 0 3px 0 #1a5a3a; }

        #skier {
            position: absolute;
            font-size: 48px;
            top: 15%;
            left: 46%;
            z-index: 10;
            transition: left 0.03s linear;
            filter: drop-shadow(3px 5px 8px rgba(0,0,0,0.3));
            pointer-events: none;
            transform: translateX(-50%);
        }

        .tree, .word-item {
            position: absolute;
            pointer-events: none;
        }
        .tree { font-size: 45px; filter: drop-shadow(2px 4px 6px rgba(0,0,0,0.2)); }
        .word-item {
            background: #e8f0ff;
            border: 2px solid #2c5a7a;
            color: #1a3a5a;
            padding: 4px 12px;
            border-radius: 40px;
            font-weight: bold;
            font-size: 14px;
            white-space: nowrap;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            font-family: monospace;
        }

        #hud {
            position: absolute;
            top: 10px;
            left: 10px;
            right: 10px;
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            font-weight: bold;
            color: #1a3a5a;
            z-index: 20;
            background: rgba(255, 255, 255, 0.9);
            padding: 6px 14px;
            border-radius: 60px;
            backdrop-filter: blur(5px);
            border: 1px solid #ffaa33;
        }

        #difficulty-indicator {
            position: absolute;
            bottom: 10px;
            right: 10px;
            background: rgba(255,255,255,0.9);
            padding: 4px 12px;
            border-radius: 30px;
            color: #1a3a5a;
            font-size: 0.7rem;
            z-index: 20;
            border-left: 3px solid #ffaa33;
        }

        /* ========== BOTONES EN ESQUINAS INFERIORES - CORREGIDO ========== */
        .touch-btn-corner {
            position: fixed;
            bottom: 100px;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(12px);
            border: 2px solid #ffcc44;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 38px;
            font-weight: bold;
            color: white;
            cursor: pointer;
            box-shadow: 0 4px 0 #124263;
            transition: 0.03s linear;
            z-index: 150;
            pointer-events: auto;
        }

        .touch-btn-corner:active {
            transform: translateY(3px);
            box-shadow: none;
        }

        .touch-left-corner {
            left: 20px;
        }

        .touch-right-corner {
            right: 20px;
        }

        .hidden-controls {
            display: none !important;
        }

        @media (max-width: 600px) {
            .touch-btn-corner {
                width: 55px;
                height: 55px;
                font-size: 28px;
                bottom: 75px;
            }
            .touch-left-corner {
                left: 12px;
            }
            .touch-right-corner {
                right: 12px;
            }
        }

        .orientation-warning {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #000000ee;
            z-index: 1000;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            color: white;
            text-align: center;
            padding: 20px;
        }
        .orientation-warning.show { display: flex; }
        .orientation-warning span { font-size: 4rem; margin-bottom: 20px; }
        .orientation-warning button { background: #daa520; margin-top: 20px; padding: 12px 24px; }
    </style>
</head>
<body>

<div id="game-container">
    <div id="sky"></div>
    <div id="snow-ground"></div>
    
    <div id="hud">
        <div>🏆 PUNTOS: <span id="score-val">0</span></div>
        <div>⏱️ TIEMPO: <span id="time-val">03:00</span></div>
    </div>
    <div id="difficulty-indicator">🌲 DIFICULTAD: <span id="difficulty-level">1</span>/3</div>

    <div id="skier">⛷️</div>
    
    <!-- BOTONES EN ESQUINAS INFERIORES -->
    <div id="touch-left-corner" class="touch-btn-corner touch-left-corner hidden-controls">◀</div>
    <div id="touch-right-corner" class="touch-btn-corner touch-right-corner hidden-controls">▶</div>

    <div id="screen-start" class="screen">
        <h1>❄️ ESQUIADOR COMUNICACIONAL ❄️</h1>
        <p>📱 Flechas táctiles (aparecen al jugar) o teclado ← →<br>📌 Recoger palabras del texto +50pts | Otras -30pts<br>💥 Evitá los árboles 🌲 | ⏱️ Recorré la pista en 2 minutos </p>
        <div class="ranking-table">
            <h2>🏆 RANKING (TOP 5)</h2>
            <table id="ranking-table-start"><thead><tr><th>#</th><th>JUGADOR</th><th>PUNTOS</th></tr></thead><tbody id="ranking-body-start"></tbody></table>
        </div>
        <input type="text" id="player-name" placeholder="NOMBRE DEL ESQUIADOR" maxlength="20">
        <button id="btn-start-game" style="background:#2e8b57;">🎿 INICIAR TRAVESÍA</button>
        <p> 🙂 CC BY-NC-SA </p>
    </div>


    <div id="screen-end" class="screen hidden">
        <h1 id="end-title">💥 ¡FIN DE LA CARRERA!</h1>
        <p id="end-message" style="color:#ffdd99;">Chocaste con un árbol</p>
        <p>PUNTUACIÓN: <span id="final-score">0</span></p>
        <div class="ranking-table"><h2>🏆 RANKING (TOP 5)</h2>
            <table id="ranking-table-end"><thead><tr><th>#</th><th>JUGADOR</th><th>PUNTOS</th></tr></thead><tbody id="ranking-body-end"></tbody></table>
        </div>
        <div class="btn-group" id="end-buttons"><button id="btn-restart" style="background:#daa520;">🎿 REANUDAR</button></div>
    </div>
</div>

<div id="orientation-warning" class="orientation-warning">
    <span>📱🔄</span>
    <p>Por favor, girá el dispositivo a posición VERTICAL</p>
    <button id="understood-btn">Entendido</button>
</div>

<script>
    const GOOD_WORDS = ["SEMIÓTICA", "SIGNIFICACIÓN", "SIGNO", "LENGUAJE", "COMUNICACIÓN", "CÓDIGO", "CODIFICAR", "DECODIFICAR", "INTERACCIÓN", "MENSAJE", "SENTIDO", "LINGÜÍSTICO", "VERBAL", "NO VERBAL", "NO LINGÜÍSTICO", "VISUAL", "ICÓNICO", "GESTUAL", "CORPORAL", "LUMÍNICO", "CROMÁTICO", "SONORO", "TÁCTIL", "MIXTO", "COMPETENCIA"];
    const BAD_WORDS = ["ESQUÍES", "BOTAS", "BASTONES", "CASCO", "ANTIPARRAS", "CAMPERA", "PANTALÓN", "GUANTES", "MEDIAS", "BUZO", "CHOCOLATE", "TERMOS", "MOCHILA", "REMERA", "GORRO", "BUFANDA", "BOTELLA", "MAPA", "BRÚJULA", "LINTERNA", "CELULAR", "RELOJ", "CAMARA", "SILLA"];

    const skier = document.getElementById('skier');
    const gameContainer = document.getElementById('game-container');
    const scoreVal = document.getElementById('score-val');
    const timeVal = document.getElementById('time-val');
    const difficultySpan = document.getElementById('difficulty-level');
    const touchLeftCorner = document.getElementById('touch-left-corner');
    const touchRightCorner = document.getElementById('touch-right-corner');
    const screenStart = document.getElementById('screen-start');
    const screenEnd = document.getElementById('screen-end');
    const endTitle = document.getElementById('end-title');
    const endMessage = document.getElementById('end-message');
    const finalScoreSpan = document.getElementById('final-score');
    const endButtons = document.getElementById('end-buttons');
    const playerNameInput = document.getElementById('player-name');
    const btnStartGame = document.getElementById('btn-start-game');
    const btnRestart = document.getElementById('btn-restart');
    const rankingBodyStart = document.getElementById('ranking-body-start');
    const rankingBodyEnd = document.getElementById('ranking-body-end');
    const orientationWarning = document.getElementById('orientation-warning');
    const understoodBtn = document.getElementById('understood-btn');

    // Creación de copos de nieve con animación diagonal
    for (let i = 0; i < 30; i++) {
        const snow = document.createElement('div');
        snow.classList.add('snowflake');
        snow.innerHTML = Math.random() > 0.7 ? '❄️' : '•';
        snow.style.left = Math.random() * 100 + '%';
        snow.style.fontSize = (Math.random() * 20 + 10) + 'px';
        snow.style.animationDuration = (Math.random() * 5 + 3) + 's';
        snow.style.animationDelay = (Math.random() * 5) + 's';
        // Añadir un pequeño offset aleatorio en la dirección X para que no caigan todos igual
        const randomDirection = (Math.random() - 0.5) * 40; // Entre -20px y +20px
        snow.style.setProperty('--diagonal-offset', randomDirection + 'px');
        document.getElementById('sky').appendChild(snow);
    }

    let skierX = 0.46, skierSpeed = 0.008, score = 0, timeElapsed = 0;
    const MAX_TIME = 2 * 60 * 1000;
    let isPlaying = false, gameLoopInterval = null, spawnTreeInterval = null, spawnWordInterval = null, currentDifficulty = 1, gameElements = [];
    let leftPressed = false, rightPressed = false;

    function updateSkierPosition() {
        const rect = gameContainer.getBoundingClientRect();
        let minLeft = rect.width * 0.05, maxLeft = rect.width * 0.95;
        let leftPx = skierX * rect.width;
        leftPx = Math.min(maxLeft, Math.max(minLeft, leftPx));
        skier.style.left = leftPx + 'px';
        skierX = leftPx / rect.width;
    }

    function moveSkier() {
        if (!isPlaying) return;
        if (leftPressed) skierX -= skierSpeed;
        if (rightPressed) skierX += skierSpeed;
        skierX = Math.min(0.94, Math.max(0.06, skierX));
        updateSkierPosition();
        if (leftPressed) skier.style.transform = "translateX(-50%) scaleX(1)";
        if (rightPressed) skier.style.transform = "translateX(-50%) scaleX(-1)";
    }

    function getRanking() { return JSON.parse(localStorage.getItem('skiRankingVertical')) || []; }
    function saveScoreToRanking(name, points) { let r = getRanking(); r.push({ name: name.toUpperCase().slice(0,20), points: points }); r.sort((a,b) => b.points - a.points); localStorage.setItem('skiRankingVertical', JSON.stringify(r.slice(0,5))); }
    function updateRankingTables() {
        let r = getRanking();
        const upd = (tbody) => { if(!tbody) return; tbody.innerHTML = ''; if(r.length===0) { tbody.innerHTML = '<tr><td colspan="3">✨ Sin registros ✨</td></tr>'; return; } r.forEach((e,i) => { tbody.innerHTML += `<tr><td>${i+1}</td><td>${e.name}</td><td>${e.points}</td></tr>`; }); };
        upd(rankingBodyStart); upd(rankingBodyEnd);
    }

    function createTree() { if(!isPlaying) return; const t = document.createElement('div'); t.classList.add('tree'); t.innerText = "🌲"; const rect = gameContainer.getBoundingClientRect(); t.style.left = (Math.random() * (rect.width * 0.9) + rect.width * 0.05) + 'px'; t.style.top = rect.height + 20 + 'px'; gameContainer.appendChild(t); gameElements.push({ element: t, type: 'tree' }); }
    function createWord() { if(!isPlaying) return; const isGood = Math.random() > 0.5; const word = (isGood ? GOOD_WORDS : BAD_WORDS)[Math.floor(Math.random() * (isGood ? GOOD_WORDS.length : BAD_WORDS.length))]; const w = document.createElement('div'); w.classList.add('word-item'); w.innerText = word; const rect = gameContainer.getBoundingClientRect(); let maxLeft = rect.width - 60, minLeft = rect.width * 0.05; w.style.left = Math.floor(Math.random() * (maxLeft - minLeft) + minLeft) + 'px'; w.style.top = rect.height + 30 + 'px'; gameContainer.appendChild(w); gameElements.push({ element: w, type: 'word', isGood: isGood }); }

    function updateDifficulty() { let nd = Math.min(3, Math.floor(timeElapsed / 40000) + 1); if(nd !== currentDifficulty) { currentDifficulty = nd; difficultySpan.innerText = currentDifficulty; if(spawnTreeInterval) { clearInterval(spawnTreeInterval); spawnTreeInterval = setInterval(() => createTree(), Math.max(300, 1200 - (currentDifficulty-1)*180)); } if(spawnWordInterval) { clearInterval(spawnWordInterval); spawnWordInterval = setInterval(() => createWord(), Math.max(1200, 2000 - (currentDifficulty-1)*160)); } } }

    function updateGame() {
        if(!isPlaying) return;
        moveSkier();
        timeElapsed += 20;
        let timeLeft = MAX_TIME - timeElapsed;
        if(timeLeft <= 0) { finishGame(true); return; }
        let sec = Math.floor(timeLeft/1000), min = Math.floor(sec/60); sec %= 60;
        timeVal.innerText = `${min.toString().padStart(2,'0')}:${sec.toString().padStart(2,'0')}`;
        updateDifficulty();
        const skierRect = skier.getBoundingClientRect();
        for(let i=gameElements.length-1; i>=0; i--) {
            let it = gameElements[i];
            let y = parseFloat(it.element.style.top);
            if(isNaN(y)) y = 0;
            y -= 2.5;
            it.element.style.top = y + 'px';
            if(y < -80) { it.element.remove(); gameElements.splice(i,1); continue; }
            const itemRect = it.element.getBoundingClientRect();
            const collide = skierRect.left < itemRect.right && skierRect.right > itemRect.left && skierRect.top < itemRect.bottom && skierRect.bottom > itemRect.top;
            if(collide) {
                if(it.type === 'tree') { finishGame(false); return; }
                if(it.type === 'word') {
                    if(it.isGood) score += 50; else score = Math.max(0, score - 30);
                    scoreVal.innerText = score;
                    it.element.remove(); gameElements.splice(i,1);
                }
            }
        }
    }

    function finishGame(victory) {
        if(!isPlaying) return;
        isPlaying = false;
        if(gameLoopInterval) clearInterval(gameLoopInterval);
        if(spawnTreeInterval) clearInterval(spawnTreeInterval);
        if(spawnWordInterval) clearInterval(spawnWordInterval);
        if(touchLeftCorner) touchLeftCorner.classList.add('hidden-controls');
        if(touchRightCorner) touchRightCorner.classList.add('hidden-controls');
        let name = playerNameInput.value.trim() || "ANÓNIMO";
        saveScoreToRanking(name, score);
        updateRankingTables();
        const old = document.getElementById('btn-continue'); if(old) old.remove();
        if(victory) {
            endTitle.innerText = "🏆 ¡VICTORIA! 🏆";
            endMessage.innerText = "¡Completaste los 2 minutos!";
            const link = document.createElement('a'); link.id = 'btn-continue'; link.textContent = '🚗 SEGUIR VIAJE'; link.href = "https://sites.google.com/view/materialestfi/malargue/insignia-mgue"; link.target = "_blank"; link.className = 'travel-link'; endButtons.appendChild(link);
        } else {
            endTitle.innerText = "💥 ¡FIN DE LA CARRERA!";
            endMessage.innerText = "Chocaste con un árbol.";
        }
        finalScoreSpan.innerText = score;
        screenEnd.classList.remove('hidden');
    }

    function startGameSession() {
        if(isPlaying) return;
        gameElements.forEach(e => e.element.remove()); gameElements = [];
        score = 0; timeElapsed = 0; currentDifficulty = 1;
        skierX = 0.46; updateSkierPosition(); skier.style.transform = "translateX(-50%) scaleX(-1)";
        scoreVal.innerText = "0"; timeVal.innerText = "02:00"; difficultySpan.innerText = "1";
        leftPressed = false; rightPressed = false;
        isPlaying = true;
        screenStart.classList.add('hidden'); screenEnd.classList.add('hidden');
        if(touchLeftCorner) touchLeftCorner.classList.remove('hidden-controls');
        if(touchRightCorner) touchRightCorner.classList.remove('hidden-controls');
        gameLoopInterval = setInterval(() => updateGame(), 20);
        spawnTreeInterval = setInterval(() => createTree(), 1800);
        spawnWordInterval = setInterval(() => createWord(), 2800);
    }

    function restartGame() {
        if(gameLoopInterval) clearInterval(gameLoopInterval);
        if(spawnTreeInterval) clearInterval(spawnTreeInterval);
        if(spawnWordInterval) clearInterval(spawnWordInterval);
        gameElements.forEach(e => e.element.remove()); gameElements = [];
        isPlaying = false;
        startGameSession();
    }

    window.addEventListener('keydown', (e) => { if(!isPlaying) return; if(e.key === 'ArrowLeft') { e.preventDefault(); leftPressed = true; } if(e.key === 'ArrowRight') { e.preventDefault(); rightPressed = true; } });
    window.addEventListener('keyup', (e) => { if(e.key === 'ArrowLeft') leftPressed = false; if(e.key === 'ArrowRight') rightPressed = false; });

    if(touchLeftCorner) { touchLeftCorner.addEventListener('touchstart', (e) => { e.preventDefault(); if(isPlaying) leftPressed = true; }); touchLeftCorner.addEventListener('touchend', (e) => { e.preventDefault(); leftPressed = false; }); touchLeftCorner.addEventListener('mousedown', () => { if(isPlaying) leftPressed = true; }); touchLeftCorner.addEventListener('mouseup', () => { leftPressed = false; }); }
    if(touchRightCorner) { touchRightCorner.addEventListener('touchstart', (e) => { e.preventDefault(); if(isPlaying) rightPressed = true; }); touchRightCorner.addEventListener('touchend', (e) => { e.preventDefault(); rightPressed = false; }); touchRightCorner.addEventListener('mousedown', () => { if(isPlaying) rightPressed = true; }); touchRightCorner.addEventListener('mouseup', () => { rightPressed = false; }); }

    let warningVisible = false;
    function checkOrientation() {
        const isMobile = /Android|webOS|iPhone|iPad|iPod/i.test(navigator.userAgent);
        if(!isMobile) return;
        const isLandscape = window.innerWidth > window.innerHeight;
        if(isLandscape && !warningVisible) { orientationWarning.classList.add('show'); warningVisible = true; }
        else if(!isLandscape && warningVisible) { orientationWarning.classList.remove('show'); warningVisible = false; }
    }
    understoodBtn.addEventListener('click', () => { orientationWarning.classList.remove('show'); warningVisible = false; });
    window.addEventListener('resize', () => { checkOrientation(); if(isPlaying) updateSkierPosition(); });
    window.addEventListener('orientationchange', () => { setTimeout(checkOrientation, 50); setTimeout(() => { if(isPlaying) updateSkierPosition(); }, 100); });

    btnStartGame.addEventListener('click', startGameSession);
    btnRestart.addEventListener('click', restartGame);
    updateSkierPosition(); updateRankingTables(); checkOrientation();
</script>
</body>
</html>
