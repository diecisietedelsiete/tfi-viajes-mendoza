<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Rafting Semiótico - San Rafael | PC + Móvil Vertical</title>
    <style>
        * {
            user-select: none;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, #0a2a3a, #021016);
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Orbitron', 'Segoe UI', 'Courier New', monospace;
            overflow: hidden;
            position: fixed;
            padding: 0;
        }

        /* Contenedor principal - adaptable a PC y móvil */
        #game-container {
            position: relative;
            width: 100%;
            height: 100%;
            max-width: 100%;
            max-height: 100%;
            background-color: #4a9aba;
            overflow: hidden;
            box-shadow: none;
            border: none;
        }

        /* En PC: tamaño fijo y centrado, siempre vertical */
        @media (min-width: 768px) {
            body {
                padding: 20px;
            }
            #game-container {
                border-radius: 28px;
                box-shadow: 0 25px 45px rgba(0, 0, 0, 0.5);
                border: 3px solid #2a6a5a;
                max-width: 500px;
                max-height: 90vh;
                width: 100%;
                height: auto;
                aspect-ratio: 9 / 16;
            }
        }

        /* Fondo del río */
        #river {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #3c8db0, #1f607a);
        }

        /* Olas animadas */
        .wave {
            position: absolute;
            background: rgba(255, 255, 255, 0.25);
            border-radius: 50%;
            animation: wave 3s infinite ease-in-out;
            pointer-events: none;
        }
        @keyframes wave {
            0% { transform: scale(1) translateY(0); opacity: 0.4; }
            50% { transform: scale(1.2) translateY(-10px); opacity: 0.7; }
            100% { transform: scale(1) translateY(0); opacity: 0.4; }
        }

        /* Orillas adaptables */
        .shore {
            position: absolute;
            width: 6%;
            min-width: 40px;
            height: 100%;
            background: #6b4c3b;
            z-index: 1;
            box-shadow: inset -2px 0 5px rgba(0,0,0,0.3);
        }
        .shore-left {
            left: 0;
            background: linear-gradient(90deg, #5d3e2e, #7a5538, #5a3926);
            border-right: 3px solid #8b5a2e;
        }
        .shore-right {
            right: 0;
            background: linear-gradient(270deg, #5d3e2e, #7a5538, #5a3926);
            border-left: 3px solid #8b5a2e;
        }
        .shore-decoration {
            position: absolute;
            font-size: clamp(16px, 4vh, 30px);
            pointer-events: none;
            text-shadow: 0 2px 4px black;
        }

        /* Pantallas flotantes */
        .screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(145deg, #031a24, #010e14);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            backdrop-filter: blur(3px);
            overflow-y: auto;
            padding: 16px;
            box-sizing: border-box;
        }

        .screen.hidden {
            display: none;
        }

        .screen h1 {
            color: #FFE5B4;
            font-size: clamp(1.3rem, 5vh, 1.9rem);
            text-shadow: 0 0 8px #ffaa33, 0 2px 4px black;
            margin-bottom: 12px;
            text-align: center;
            font-weight: bold;
        }

        .screen p {
            color: #f0f9ff;
            text-shadow: 0 1px 2px black;
            font-weight: bold;
            background: rgba(0,0,0,0.6);
            padding: 6px 12px;
            border-radius: 28px;
            margin: 6px 16px;
            font-size: clamp(0.7rem, 2.5vh, 0.9rem);
        }

        .ranking-table {
            background: #07161f;
            border-radius: 16px;
            padding: 10px;
            margin: 10px 0;
            border: 2px solid #FFC857;
            width: 90%;
            max-width: 380px;
            box-shadow: 0 4px 12px black;
        }

        .ranking-table h2 {
            color: #FFD966;
            text-shadow: 0 1px 2px black;
            margin-top: 0;
            font-size: clamp(1rem, 4vh, 1.3rem);
        }

        .ranking-table table {
            width: 100%;
            border-collapse: collapse;
            color: #FFFFFF;
            font-size: clamp(0.65rem, 2.5vh, 0.85rem);
            font-weight: bold;
        }

        .ranking-table th, .ranking-table td {
            padding: 6px;
            text-align: center;
            border-bottom: 1px solid #3e7a8c;
        }

        .ranking-table th {
            color: #FFD966;
            background: #0a2a34;
        }

        input {
            padding: 10px 18px;
            border-radius: 50px;
            border: none;
            background: #FFF3DF;
            font-size: clamp(0.75rem, 3vh, 0.95rem);
            text-align: center;
            margin: 8px 0;
            font-family: monospace;
            font-weight: bold;
            width: 80%;
            max-width: 240px;
            box-shadow: 0 2px 6px black;
            color: #1a2a3a;
        }

        button, .travel-link {
            background: #f0a500;
            border: none;
            padding: 10px 20px;
            border-radius: 50px;
            color: #1f2a0e;
            font-weight: bold;
            font-family: monospace;
            font-size: clamp(0.75rem, 3vh, 0.95rem);
            cursor: pointer;
            margin: 5px;
            transition: 0.05s linear;
            box-shadow: 0 4px 0 #7a4a00;
            text-decoration: none;
            display: inline-block;
            text-align: center;
        }

        button:active, .travel-link:active {
            transform: translateY(2px);
            box-shadow: none;
        }

        .btn-group {
            display: flex;
            gap: 10px;
            margin-top: 10px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .travel-link {
            background: #2e7d5e;
            box-shadow: 0 3px 0 #1b4e3a;
            color: white;
        }

        /* Balsa */
        #raft {
            position: absolute;
            font-size: clamp(34px, 7vh, 58px);
            top: 46%;
            left: 46%;
            z-index: 10;
            width: auto;
            height: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: left 0.03s linear, top 0.03s linear;
            filter: drop-shadow(3px 5px 8px rgba(0,0,0,0.5));
            pointer-events: none;
            transform: translate(-50%, -50%);
        }

        .obstacle {
            position: absolute;
            font-size: clamp(30px, 6vh, 50px);
            width: auto;
            height: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            filter: drop-shadow(2px 4px 6px black);
            pointer-events: none;
        }

        .word-item {
            position: absolute;
            background: #0a1f2c;
            border: 2px solid #FFD966;
            color: #FFFBEA;
            padding: 4px 12px;
            border-radius: 40px;
            font-weight: bold;
            font-size: clamp(11px, 2.8vh, 16px);
            white-space: nowrap;
            z-index: 5;
            box-shadow: 0 4px 10px black;
            font-family: monospace;
            pointer-events: none;
            text-shadow: 0 1px 1px black;
            backdrop-filter: blur(2px);
        }

        #hud {
            position: absolute;
            top: 10px;
            left: 10px;
            right: 10px;
            display: flex;
            justify-content: space-between;
            font-size: clamp(0.75rem, 3vh, 1rem);
            font-weight: bold;
            color: #FFECB3;
            z-index: 20;
            background: rgba(0, 0, 0, 0.85);
            padding: 6px 14px;
            border-radius: 60px;
            backdrop-filter: blur(5px);
            font-family: monospace;
            text-shadow: 0 1px 2px black;
            border: 1px solid #f0a500;
        }

        #difficulty-indicator {
            position: absolute;
            bottom: 10px;
            right: 10px;
            background: rgba(0,0,0,0.85);
            padding: 4px 12px;
            border-radius: 30px;
            color: #FFB347;
            font-size: clamp(0.65rem, 2.5vh, 0.8rem);
            z-index: 20;
            font-weight: bold;
            backdrop-filter: blur(4px);
            border-left: 3px solid #ffaa33;
            font-family: monospace;
        }

        /* Panel de controles táctiles */
        #touch-controls-panel {
            position: absolute;
            bottom: 12px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            z-index: 25;
            pointer-events: none;
        }
        
        .touch-dpad {
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 80px;
            padding: 8px 16px;
            display: inline-flex;
            gap: 12px;
            pointer-events: auto;
            border: 1px solid #ffcc44;
            box-shadow: 0 6px 14px black;
        }
        
        .touch-btn {
            background: #2c6e9e;
            width: clamp(45px, 9vw, 58px);
            height: clamp(45px, 9vw, 58px);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: clamp(24px, 5vw, 32px);
            font-weight: bold;
            color: white;
            cursor: pointer;
            box-shadow: 0 4px 0 #124263;
            transition: 0.03s linear;
            user-select: none;
            touch-action: manipulation;
        }
        
        .touch-btn:active {
            transform: translateY(3px);
            box-shadow: none;
        }
        
        .hidden-controls {
            display: none !important;
        }
        
        /* Ajustes móviles */
        @media (max-width: 600px) and (max-height: 800px) {
            .touch-dpad {
                padding: 5px 12px;
                gap: 8px;
            }
            .touch-btn {
                width: 44px;
                height: 44px;
                font-size: 24px;
            }
            .screen {
                padding: 10px;
            }
            .ranking-table {
                padding: 8px;
                margin: 6px 0;
            }
        }
        
        /* Advertencia de orientación solo para móviles */
        .orientation-warning {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #000000ee;
            z-index: 1000;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            color: white;
            font-family: monospace;
            text-align: center;
            padding: 20px;
            backdrop-filter: blur(10px);
        }
        
        .orientation-warning.show {
            display: flex;
        }
        
        .orientation-warning span {
            font-size: 4rem;
            margin-bottom: 20px;
        }
        
        .orientation-warning p {
            font-size: 1.2rem;
            background: none;
            margin: 10px;
        }
        
        .orientation-warning button {
            background: #f0a500;
            margin-top: 20px;
            padding: 12px 24px;
            font-size: 1rem;
        }
    </style>
</head>
<body>

<div id="game-container">
    <div id="river"></div>
    <div id="waves-container"></div>
    
    <div class="shore shore-left"></div>
    <div class="shore shore-right"></div>
    
    <div id="hud">
        <div>🏆 PUNTOS: <span id="score-val">0</span></div>
        <div>⏱️ TIEMPO: <span id="time-val">03:00</span></div>
    </div>
    <div id="difficulty-indicator">🪨 DIFICULTAD: <span id="difficulty-level">1</span>/3</div>

    <div id="raft">🚣</div>
    
    <div id="touch-controls-panel" class="hidden-controls">
        <div class="touch-dpad">
            <div class="touch-btn" id="touch-left">◀</div>
            <div class="touch-btn" id="touch-up">▲</div>
            <div class="touch-btn" id="touch-down">▼</div>
            <div class="touch-btn" id="touch-right">▶</div>
        </div>
    </div>

    <div id="screen-start" class="screen">
        <h1>🚣 RAFTING COMUNICACIONAL 🚣</h1>
        <p>📱 Flechas táctiles (aparecen al jugar) o teclado<br>📌 Atrapá las palabras del texto: +50pts <br>📌  Te distraés con las atracciones turísticas: -30pts<br>💥 Evitá piedras 🪨 | ⏱️ Remá por 2 minutos<br><span style="color:#FFD966;">⬆️⬇️⬅️➡️ </span>¡Mové el gomón inflable!</p>
        
        <div class="ranking-table">
            <h2>🏆 RANKING (TOP 5)</h2>
            <table id="ranking-table-start">
                <thead><tr><th>#</th><th>JUGADOR</th><th>PUNTOS</th></tr></thead>
                <tbody id="ranking-body-start"></tbody>
            </table>
        </div>

        <input type="text" id="player-name" placeholder="NOMBRE DEL/DE LA REMERO/A" maxlength="20">
        
        <button id="btn-start-game" style="background:#da7a1a; color:white;">🚣 INICIAR TRAVESÍA</button>
        <p style="font-size:0.65rem;">En PC usá las flechas del teclado | En móvil los botones táctiles</p>
        <p> 🙂 CC BY-NC-SA </p>
    </div>

    <div id="screen-end" class="screen hidden">
        <h1 id="end-title">💥 ¡FIN DEL RECORRIDO!</h1>
        <p id="end-message" style="color:#FFCC88;">Chocaste con una piedra</p>
        <p style="font-size:1.2rem; font-weight:bold; background:#000000aa; padding:5px 15px; border-radius:30px;">PUNTUACIÓN: <span id="final-score">0</span></p>
        
        <div class="ranking-table">
            <h2>🏆 RANKING (TOP 5)</h2>
            <table id="ranking-table-end">
                <thead><tr><th>#</th><th>JUGADOR</th><th>PUNTOS</th></tr></thead>
                <tbody id="ranking-body-end"></tbody>
            </table>
        </div>

        <div class="btn-group" id="end-buttons">
            <button id="btn-restart" style="background:#daa520;">🚣 REANUDAR / NUEVA TRAVESÍA</button>
        </div>
    </div>
</div>

<div id="orientation-warning" class="orientation-warning">
    <span>📱🔄</span>
    <p>Por favor, girá el dispositivo a posición VERTICAL<br>para jugar al Rafting Semiótico</p>
    <button id="understood-btn">Entendido</button>
</div>

<script>
    const GOOD_WORDS = [
        "COMUNICACIÓN", "PROCESO", "HUMANO", "CREATIVAMENTE", "VIDA", "COMPRENDER",
        "RELACIONES", "PERSONAS", "INTERACCIÓN", "MEDIOS", "REDES", "CULTURA",
        "COMUNIDAD", "DIÁLOGO", "INTERCAMBIOS", "INDIVIDUAL", "GRUPAL", "SOCIAL",
        "DESARROLLO", "CAPACIDAD", "LENGUAJE", "RAZÓN", "SIGNIFICACIONES",
        "VALORES", "INTENCIONALIDADES", "INFORMACIÓN", "COMUNICACIÓN MASIVA",
        "SEMEJANTES", "EXPERIENCIA"
    ];

    const BAD_WORDS = [
        "RAFTING", "ATUEL", "DIAMANTE", "NIHUIL", "PARQUE", "RÁPIDOS", "CHOCOLATE",
        "CABAÑA", "PILETA", "ACEITUNAS", "VALLE GRANDE", "REYUNOS", "PARQUE DE LOS NIÑOS", "CAMPING"
    ];

    // DOM elements
    const raft = document.getElementById('raft');
    const gameContainer = document.getElementById('game-container');
    const scoreVal = document.getElementById('score-val');
    const timeVal = document.getElementById('time-val');
    const difficultySpan = document.getElementById('difficulty-level');
    const wavesContainer = document.getElementById('waves-container');
    const screenStart = document.getElementById('screen-start');
    const screenEnd = document.getElementById('screen-end');
    const endTitle = document.getElementById('end-title');
    const endMessage = document.getElementById('end-message');
    const finalScoreSpan = document.getElementById('final-score');
    const endButtons = document.getElementById('end-buttons');
    const playerNameInput = document.getElementById('player-name');
    const btnStartGame = document.getElementById('btn-start-game');
    const btnRestart = document.getElementById('btn-restart');
    const rankingBodyStart = document.getElementById('ranking-body-start');
    const rankingBodyEnd = document.getElementById('ranking-body-end');
    const touchControlsPanel = document.getElementById('touch-controls-panel');
    const orientationWarning = document.getElementById('orientation-warning');
    const understoodBtn = document.getElementById('understood-btn');
    
    // Olas decorativas
    for (let i = 0; i < 18; i++) {
        const wave = document.createElement('div');
        wave.classList.add('wave');
        wave.style.width = Math.random() * 60 + 30 + 'px';
        wave.style.height = wave.style.width;
        wave.style.left = Math.random() * 100 + '%';
        wave.style.top = Math.random() * 100 + '%';
        wave.style.animationDelay = Math.random() * 3 + 's';
        wavesContainer.appendChild(wave);
    }
    
    // Decorar orillas
    const leftShore = document.querySelector('.shore-left');
    const rightShore = document.querySelector('.shore-right');
    for (let i = 0; i < 12; i++) {
        const treeLeft = document.createElement('div');
        treeLeft.classList.add('shore-decoration');
        treeLeft.innerHTML = Math.random() > 0.5 ? '🌲' : '🌿';
        treeLeft.style.left = Math.random() * 30 + 5 + 'px';
        treeLeft.style.top = Math.random() * 100 + '%';
        treeLeft.style.fontSize = Math.random() * 20 + 18 + 'px';
        leftShore.appendChild(treeLeft);
        
        const treeRight = document.createElement('div');
        treeRight.classList.add('shore-decoration');
        treeRight.innerHTML = Math.random() > 0.5 ? '🌲' : '🌿';
        treeRight.style.right = Math.random() * 30 + 5 + 'px';
        treeRight.style.top = Math.random() * 100 + '%';
        treeRight.style.fontSize = Math.random() * 20 + 18 + 'px';
        rightShore.appendChild(treeRight);
    }
    
    // Variables del juego
    let raftPercentX = 0.46;
    let raftPercentY = 0.46;
    let raftSpeed = 0.012;
    let score = 0;
    let timeElapsed = 0;
    const MAX_TIME = 2 * 60 * 1000;
    let isPlaying = false;
    let gameLoopInterval = null;
    let spawnObstacleInterval = null;
    let spawnWordInterval = null;
    let currentDifficulty = 1;
    let gameElements = [];
    let leftPressed = false, rightPressed = false, upPressed = false, downPressed = false;
    
    function updateRaftPosition() {
        const rect = gameContainer.getBoundingClientRect();
        let minLeft = rect.width * 0.08;
        let maxLeft = rect.width * 0.92;
        let minTop = rect.height * 0.08;
        let maxTop = rect.height * 0.92;
        let leftPx = raftPercentX * rect.width;
        let topPx = raftPercentY * rect.height;
        leftPx = Math.min(maxLeft, Math.max(minLeft, leftPx));
        topPx = Math.min(maxTop, Math.max(minTop, topPx));
        raft.style.left = leftPx + 'px';
        raft.style.top = topPx + 'px';
        raftPercentX = leftPx / rect.width;
        raftPercentY = topPx / rect.height;
    }
    
    function moveRaft() {
        if (!isPlaying) return;
        if (leftPressed) raftPercentX -= raftSpeed;
        if (rightPressed) raftPercentX += raftSpeed;
        if (upPressed) raftPercentY -= raftSpeed;
        if (downPressed) raftPercentY += raftSpeed;
        raftPercentX = Math.min(0.94, Math.max(0.06, raftPercentX));
        raftPercentY = Math.min(0.94, Math.max(0.06, raftPercentY));
        updateRaftPosition();
    }
    
    // RANKING
    function getRanking() {
        return JSON.parse(localStorage.getItem('raftingRankingFinal')) || [];
    }
    function saveScoreToRanking(playerName, points) {
        let ranking = getRanking();
        ranking.push({ name: playerName.toUpperCase().slice(0,20), points: points });
        ranking.sort((a,b) => b.points - a.points);
        localStorage.setItem('raftingRankingFinal', JSON.stringify(ranking.slice(0,5)));
    }
    function updateRankingTables() {
        let ranking = getRanking();
        const upd = (tbody) => {
            if (!tbody) return;
            tbody.innerHTML = '';
            if (ranking.length === 0) { tbody.innerHTML = '<tr><td colspan="3">✨ Sin registros ✨</td></tr>'; return; }
            ranking.forEach((e,idx) => { tbody.innerHTML += `<tr><td>${idx+1}</td><td>${e.name}</td><td>${e.points}</td>`; });
        };
        upd(rankingBodyStart);
        upd(rankingBodyEnd);
    }
    
    // Crear objetos
    function createObstacle() {
        if (!isPlaying) return;
        const obs = document.createElement('div');
        obs.classList.add('obstacle');
        obs.innerText = ['🪨','🗻','🪨','⛰️','🪨'][Math.floor(Math.random()*5)];
        const rect = gameContainer.getBoundingClientRect();
        obs.style.left = (Math.random() * (rect.width * 0.8) + rect.width * 0.1) + 'px';
        obs.style.top = '-50px';
        gameContainer.appendChild(obs);
        gameElements.push({ element: obs, type: 'obstacle' });
    }
    function createWord() {
        if (!isPlaying) return;
        const isGood = Math.random() > 0.5;
        const list = isGood ? GOOD_WORDS : BAD_WORDS;
        const word = list[Math.floor(Math.random() * list.length)];
        const wordDiv = document.createElement('div');
        wordDiv.classList.add('word-item');
        wordDiv.innerText = word;
        const rect = gameContainer.getBoundingClientRect();
        let maxLeft = rect.width - 70;
        let minLeft = rect.width * 0.07;
        wordDiv.style.left = Math.floor(Math.random() * (maxLeft - minLeft) + minLeft) + 'px';
        wordDiv.style.top = '-40px';
        gameContainer.appendChild(wordDiv);
        gameElements.push({ element: wordDiv, type: 'word', isGood: isGood });
    }
    
    function updateDifficulty() {
        let newDiff = Math.min(3, Math.floor(timeElapsed / 40000) + 1);
        if (newDiff !== currentDifficulty) {
            currentDifficulty = newDiff;
            difficultySpan.innerText = currentDifficulty;
            if (spawnObstacleInterval) clearInterval(spawnObstacleInterval);
            if (spawnWordInterval) clearInterval(spawnWordInterval);
            let obsRate = Math.max(600, 1600 - (currentDifficulty-1)*200);
            let wordRate = Math.max(1000, 2200 - (currentDifficulty-1)*200);
            spawnObstacleInterval = setInterval(() => createObstacle(), obsRate);
            spawnWordInterval = setInterval(() => createWord(), wordRate);
        }
    }
    
    function updateGame() {
        if (!isPlaying) return;
        moveRaft();
        timeElapsed += 20;
        let timeLeft = MAX_TIME - timeElapsed;
        if (timeLeft <= 0) { finishGame(true); return; }
        let sec = Math.floor(timeLeft/1000);
        let min = Math.floor(sec/60);
        sec %= 60;
        timeVal.innerText = `${min.toString().padStart(2,'0')}:${sec.toString().padStart(2,'0')}`;
        updateDifficulty();
        
        const raftRect = raft.getBoundingClientRect();
        for (let i=gameElements.length-1; i>=0; i--) {
            let it = gameElements[i];
            let y = parseFloat(it.element.style.top);
            if (isNaN(y)) y = 0;
            y += 2.5;
            it.element.style.top = y + 'px';
            const contHeight = gameContainer.getBoundingClientRect().height;
            if (y > contHeight + 120) { it.element.remove(); gameElements.splice(i,1); continue; }
            const itemRect = it.element.getBoundingClientRect();
            const collide = raftRect.left < itemRect.right && raftRect.right > itemRect.left &&
                            raftRect.top < itemRect.bottom && raftRect.bottom > itemRect.top;
            if (collide) {
                if (it.type === 'obstacle') { finishGame(false); return; }
                if (it.type === 'word') {
                    if (it.isGood) score += 50;
                    else score = Math.max(0, score - 30);
                    scoreVal.innerText = score;
                    it.element.remove();
                    gameElements.splice(i,1);
                }
            }
        }
    }
    
    function finishGame(victory) {
        if (!isPlaying) return;
        isPlaying = false;
        if (gameLoopInterval) clearInterval(gameLoopInterval);
        if (spawnObstacleInterval) clearInterval(spawnObstacleInterval);
        if (spawnWordInterval) clearInterval(spawnWordInterval);
        touchControlsPanel.classList.add('hidden-controls');
        let name = playerNameInput.value.trim();
        if (name === "") name = "ANÓNIMO";
        saveScoreToRanking(name, score);
        updateRankingTables();
        const oldCont = document.getElementById('btn-continue');
        if (oldCont) oldCont.remove();
        if (victory) {
            endTitle.innerText = "🏆 ¡VICTORIA! 🏆";
            endMessage.innerText = "¡Completaste los 2 minutos! Llegaste al final del río.";
            const link = document.createElement('a');
            link.id = 'btn-continue';
            link.textContent = '🚗 SEGUIR VIAJE';
            link.href = "https://sites.google.com/view/materialestfi/san-rafael/insignia-sraf";
            link.target = "_blank";
            link.rel = "noopener noreferrer";
            link.className = 'travel-link';
            endButtons.appendChild(link);
        } else {
            endTitle.innerText = "💥 ¡FIN DEL RECORRIDO!";
            endMessage.innerText = "Chocaste con una piedra. ¡El río no perdona!";
        }
        finalScoreSpan.innerText = score;
        screenEnd.classList.remove('hidden');
    }
    
    function startGameSession() {
        if (isPlaying) return;
        gameElements.forEach(e => e.element.remove());
        gameElements = [];
        score = 0; timeElapsed = 0; currentDifficulty = 1;
        raftPercentX = 0.46; raftPercentY = 0.46;
        updateRaftPosition();
        scoreVal.innerText = "0";
        timeVal.innerText = "02:00";
        difficultySpan.innerText = "1";
        leftPressed = false; rightPressed = false; upPressed = false; downPressed = false;
        isPlaying = true;
        screenStart.classList.add('hidden');
        screenEnd.classList.add('hidden');
        touchControlsPanel.classList.remove('hidden-controls');
        
        gameLoopInterval = setInterval(() => updateGame(), 20);
        spawnObstacleInterval = setInterval(() => createObstacle(), 2800);
        spawnWordInterval = setInterval(() => createWord(), 2000);
    }
    
    function restartGame() {
        if (gameLoopInterval) clearInterval(gameLoopInterval);
        if (spawnObstacleInterval) clearInterval(spawnObstacleInterval);
        if (spawnWordInterval) clearInterval(spawnWordInterval);
        gameElements.forEach(e => e.element.remove());
        gameElements = [];
        isPlaying = false;
        touchControlsPanel.classList.add('hidden-controls');
        startGameSession();
    }
    
    // CONTROLES TECLADO (para PC)
    window.addEventListener('keydown', (e) => {
        if (!isPlaying) return;
        if (e.key === 'ArrowLeft') { e.preventDefault(); leftPressed = true; }
        if (e.key === 'ArrowRight') { e.preventDefault(); rightPressed = true; }
        if (e.key === 'ArrowUp') { e.preventDefault(); upPressed = true; }
        if (e.key === 'ArrowDown') { e.preventDefault(); downPressed = true; }
    });
    window.addEventListener('keyup', (e) => {
        if (e.key === 'ArrowLeft') leftPressed = false;
        if (e.key === 'ArrowRight') rightPressed = false;
        if (e.key === 'ArrowUp') upPressed = false;
        if (e.key === 'ArrowDown') downPressed = false;
    });
    
    // CONTROLES TÁCTILES (para móvil)
    const touchUp = document.getElementById('touch-up');
    const touchDown = document.getElementById('touch-down');
    const touchLeft = document.getElementById('touch-left');
    const touchRight = document.getElementById('touch-right');
    const attachTouch = (btn, setter) => {
        if(!btn) return;
        btn.addEventListener('touchstart', (e) => { e.preventDefault(); if(isPlaying) setter(true); });
        btn.addEventListener('touchend', (e) => { e.preventDefault(); if(isPlaying) setter(false); });
        btn.addEventListener('mousedown', () => { if(isPlaying) setter(true); });
        btn.addEventListener('mouseup', () => { if(isPlaying) setter(false); });
    };
    attachTouch(touchUp, (v) => upPressed = v);
    attachTouch(touchDown, (v) => downPressed = v);
    attachTouch(touchLeft, (v) => leftPressed = v);
    attachTouch(touchRight, (v) => rightPressed = v);
    
    // ORIENTACIÓN - Solo para móviles, advierte pero no bloquea la funcionalidad
    let warningVisible = false;
    function checkOrientation() {
        const isMobile = /Android|webOS|iPhone|iPad|iPod/i.test(navigator.userAgent);
        if (!isMobile) return;
        const isLandscape = window.innerWidth > window.innerHeight;
        if (isLandscape && !warningVisible) {
            orientationWarning.classList.add('show');
            warningVisible = true;
        } else if (!isLandscape && warningVisible) {
            orientationWarning.classList.remove('show');
            warningVisible = false;
        }
    }
    
    understoodBtn.addEventListener('click', () => {
        orientationWarning.classList.remove('show');
        warningVisible = false;
    });
    
    window.addEventListener('resize', () => {
        checkOrientation();
        updateRaftPosition();
    });
    window.addEventListener('orientationchange', () => {
        setTimeout(checkOrientation, 50);
        setTimeout(updateRaftPosition, 100);
    });
    
    // Inicialización
    btnStartGame.addEventListener('click', startGameSession);
    btnRestart.addEventListener('click', restartGame);
    updateRaftPosition();
    updateRankingTables();
    if (!localStorage.getItem('raftingRankingFinal')) localStorage.setItem('raftingRankingFinal', JSON.stringify([]));
    updateRankingTables();
    touchControlsPanel.classList.add('hidden-controls');
    checkOrientation();
</script>
</body>
</html>
